# Supabase (Settings > API 에서 복사)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — Pi에만! 웹에 절대 금지

# 현장·기기 식별
SITE_ID=demo-site
PI_ID=pi-1

# 시리얼 포트 — 반드시 by-id 경로 사용 (부팅마다 ttyACM 번호가 바뀜)
# 확인: ls /dev/serial/by-id/
SERIAL_PORT_A=/dev/serial/by-id/usb-XXXX_A   # 문 바깥쪽 수신기
SERIAL_PORT_B=/dev/serial/by-id/usb-XXXX_B   # 문 안쪽 수신기
